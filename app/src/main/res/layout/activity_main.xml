<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Camera preview -->
    <TextureView
        android:id="@+id/textureView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/controlsPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Controls panel -->
    <LinearLayout
        android:id="@+id/controlsPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#AA000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/isoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ISO: 100"
            android:textColor="#FFFFFF"/>

        <SeekBar
            android:id="@+id/isoSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="3200"/>

        <TextView
            android:id="@+id/shutterLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shutter: 1/100"
            android:textColor="#FFFFFF"/>

        <SeekBar
            android:id="@+id/shutterSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"/>

        <TextView
            android:id="@+id/focusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Focus: auto"
            android:textColor="#FFFFFF"/>

        <SeekBar
            android:id="@+id/focusSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">
        <ImageButton
            android:id="@+id/captureBtn"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@android:color/transparent"
            android:contentDescription="Capture"/>

            <Button
                android:id="@+id/modeButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/transparent"
                android:text="Mode: RAW"/>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
